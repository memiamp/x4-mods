<?xml version="1.0" encoding="utf-8"?>
<diff>
  <replace sel="//order[@id='CollectDropsInRadius']/params/param[@name='radius']/@default">350km</replace>
  <replace sel="//order[@id='CollectDropsInRadius']/params/param[@name='radius']/input_param[@name='max']/@value">350km</replace>
  <replace sel="//attention[@min='unknown']/actions/do_if[@value='this.sector != $destination.{1} or this.assignedcontrolled.distanceto.{$destination} gt 10km']/@value">this.sector != $destination.{1}</replace>
  <add sel="//attention[@min='unknown']/actions/find_object" type="@sortbydistanceto">this</add>
  <remove sel="//attention[@min='unknown']/actions/find_object/match_distance" />
  
  <add sel="//label[@name='finish']" pos="after">
    <!-- Automatically sell ammo -->
    <set_value name="$message" exact="''"/>
    <set_value name="$totalSellValue" exact="0"/>
    <do_all exact="this.assignedcontrolled.ammostorage.missile.table.keys.count" counter="$r" reverse="true">
      <set_value name="$missile" exact="this.assignedcontrolled.ammostorage.missile.table.keys.{$r}"/>
      <set_value name="$amount" exact="this.assignedcontrolled.ammostorage.missile.table.{$missile}"/>
      <set_value name="$sellValue" exact="$missile.ware.averageprice * $amount"/>
        
      <remove_ammo object="this.assignedcontrolled" macro="$missile" amount="$amount"/>
      
      <set_value name="$totalSellValue" exact="($totalSellValue + $sellValue)"/>
      <set_value name="$message" exact="$message + {20102, 3}.[$missile.ware.name, $amount, $sellValue.formatted.default]"/>
    </do_all>
    
		<do_if value="$message != ''">
			<write_to_logbook category="general" title="{20102, 1}" text="{20102, 4}.[this.assignedcontrolled.name, this.assignedcontrolled.idcode, $message, $totalSellValue.formatted.default]"/>
		</do_if>
    
    <do_if value="$totalSellValue gt 0">
      <reward_player money="$totalSellValue" />
    </do_if>
    
    <!-- Automatically sell cargo -->
    <set_value name="$message" exact="''"/>
    <set_value name="$totalSellValue" exact="0"/>
    <do_all exact="this.assignedcontrolled.cargo.table.keys.count" counter="$r" reverse="true">
      <set_value name="$ware" exact="this.assignedcontrolled.cargo.table.keys.{$r}"/>
      <set_value name="$amount" exact="this.assignedcontrolled.cargo.table.{$ware}"/>
      <set_value name="$sellValue" exact="$ware.averageprice * $amount"/>

      <remove_cargo object="this.assignedcontrolled" ware="$ware" exact="$amount"/>
      
      <set_value name="$totalSellValue" exact="($totalSellValue + $sellValue)"/>
      <set_value name="$message" exact="$message + {20102, 3}.[$ware.name, $amount, $sellValue.formatted.default]"/>
    </do_all>
    
		<do_if value="$message != ''">
			<write_to_logbook category="general" title="{20102, 2}" text="{20102, 4}.[this.assignedcontrolled.name, this.assignedcontrolled.idcode, $message, $totalSellValue.formatted.default]"/>
		</do_if>
    
    <do_if value="$totalSellValue gt 0">
      <reward_player money="$totalSellValue" />
    </do_if>
  </add>
</diff>
